{
  "name": "cmm",
  "version": "0.1.0",
  "description": "CC-tree — CLAUDE.md context map for Claude Code",
  "type": "module",
  "bin": {
    "cmm": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "src/web/"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsc && node -e \"const{cpSync,mkdirSync,existsSync}=require('fs');const{join}=require('path');const src=join(__dirname,'src','web');const dst=join(__dirname,'dist','web');if(!existsSync(dst))mkdirSync(dst,{recursive:true});cpSync(src,dst,{recursive:true})\"",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
